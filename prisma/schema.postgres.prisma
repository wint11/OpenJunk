datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  password  String?  // Hashed password
  role      String   @default("USER") // USER, AUTHOR, ADMIN, SUPER_ADMIN
  status    String   @default("ACTIVE") // ACTIVE, BANNED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Admin Roles
  managedJournalId String? @unique
  managedJournal   Journal? @relation("JournalAdmin", fields: [managedJournalId], references: [id])
  
  managedConferenceId String?
  managedConference   Conference? @relation("ConferenceAdmin", fields: [managedConferenceId], references: [id])

  managedAwardId      String?
  managedAward        Award?      @relation("AwardAdmin", fields: [managedAwardId], references: [id])

  reviewerJournals Journal[] @relation("JournalReviewers")
  reviewerConferences Conference[] @relation("ConferenceReviewers")

  readingHistory ReadingHistory[]
  uploadedNovels Novel[]          @relation("UserUploads")
  uploadedPreprints Preprint[]
  awardApplications AwardApplication[]
  auditLogs      AuditLog[]
  reviews        ReviewLog[]
  
  notifications  Notification[] @relation("UserNotifications")
  sentNotifications Notification[] @relation("SenderNotifications")
  
  comments       Comment[]
  novelReviewComments NovelReviewComment[]
  commentLikes   CommentLike[]

  // Fund System Relations
  fundAdminCategories FundCategory[] @relation("FundCategoryAdmins")
  fundExpertProfile   FundExpertProfile?
  
  // Award System
  publishedAnnouncements AwardAnnouncement[]

  // Rate Limiting
  aiDesignUsage String? // JSON: { date: "2024-03-20", count: 5 }
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  
  senderId  String?
  sender    User?    @relation("SenderNotifications", fields: [senderId], references: [id])
  
  type      String   // INVITATION, SYSTEM, REVIEW
  title     String
  content   String
  status    String   @default("UNREAD") // UNREAD, READ, ACCEPTED, REJECTED
  
  data      String?  // JSON string for storing related IDs (e.g. { journalId: "..." })
  
  createdAt DateTime @default(now())
}

model Novel {
  id          String   @id @default(cuid())
  title       String
  author      String   // Display author name
  correspondingAuthor String? // Corresponding author name
  extraAuthors String? // JSON string of additional authors
  description String
  coverUrl    String?
  pdfUrl      String?  // URL to the full text PDF
  pdfHash     String?  // SHA-256 hash of the PDF file for deduplication
  pendingCoverUrl String? // For cover update requests
  category    String
  type        String   @default("NOVEL") // NOVEL, PAPER, AUTOBIOGRAPHY, ARTICLE
  status      String   @default("DRAFT") // DRAFT, PENDING, PUBLISHED, REJECTED, PENDING_DELETION, TAKEDOWN
  serializationStatus String @default("SERIALIZING") // SERIALIZING, COMPLETED
  isRecommended Boolean @default(false) // Featured on home page
  
  // Audit/Review fields
  lastSubmittedAt DateTime?
  lastApprovedAt  DateTime?
  changeLog      String?   // JSON string or text describing changes since last approval

  aiReviewPassed Boolean?
  aiQuality     Int?
  aiReviewedAt  DateTime?
  aiReviewRaw   String?
  views       Int      @default(0)
  popularity  Float    @default(0) // Dynamic heat/popularity score
  rating      Float    @default(0)

  // AOI System (Academic Overreach Index)
  aoiScore          Float?   @default(0) // Final calculated AOI
  aiRigor           Float?   @default(0) // 严谨性 (0-10)
  aiReproducibility Float?   @default(0) // 可复现性 (0-10)
  aiStandardization Float?   @default(0) // 规范性 (0-10)
  aiProfessionalism Float?   @default(0) // 专业性 (0-10)
  aiObjectivity     Float?   @default(0) // 客观性 (0-10)
  
  aoiVotes          AoiVote[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  uploaderId  String?
  uploader    User?    @relation("UserUploads", fields: [uploaderId], references: [id])
  uploaderIp  String?  // Record IP address for anonymous submissions

  journalId   String?
  journal     Journal? @relation(fields: [journalId], references: [id])
  
  conferenceId String?
  conference   Conference? @relation(fields: [conferenceId], references: [id])
  
  submissionTargets Journal[] @relation("SubmissionTargets")

  awardApplications AwardApplication[] @relation("AwardNominationPapers")
  
  // 关联基金项目 (Optional)
  // 修改为多对多关联 FundApplication (具体立项项目)
  fundApplications FundApplication[]

  chapters    Chapter[]
  readingHistory ReadingHistory[]
  reviewLogs  ReviewLog[]
  comments    Comment[]
  novelReviewComments NovelReviewComment[]
}

model NovelReviewComment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  guestName String?
  guestIp   String?
  
  novelId   String
  novel     Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  
  // Optional: Track if this comment is part of an official review action
  action    String?  // REJECT, MINOR_REVISION, MAJOR_REVISION, COMMENT, etc.
  
  // Optional parent comment for replies
  parentId  String?
  parent    NovelReviewComment? @relation("NovelReviewCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   NovelReviewComment[] @relation("NovelReviewCommentReplies")
}

model ReviewLog {
  id        String   @id @default(cuid())
  novelId   String
  novel     Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  
  reviewerId String
  reviewer   User    @relation(fields: [reviewerId], references: [id])
  
  action    String   // APPROVE, REJECT
  feedback  String?  // Feedback to author
  
  createdAt DateTime @default(now())
}

model Chapter {
  id        String   @id @default(cuid())
  title     String
  content   String
  order     Int
  novelId   String
  novel     Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  status    String   @default("DRAFT") // DRAFT, PENDING, PUBLISHED, REJECTED
  
  isVip     Boolean  @default(false)

  isModified Boolean @default(false) // Track if modified since last submission

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  readingHistory ReadingHistory[]

  @@index([novelId])
}

model ReadingHistory {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  guestName String?  // For anonymous users: "匿名用户xxxx"
  guestIp   String?  // Store IP for rate limiting/blocking if needed
  novelId   String
  novel     Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapterId String
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt

  @@unique([userId, novelId])
  @@index([userId])
  @@index([novelId])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  resource  String
  details   String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  ipAddress String?
  createdAt DateTime @default(now())
}

model AppSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GhostMessage {
  id        String   @id @default(cuid())
  content   String
  author    String?  @default("ANONYMOUS") // Username or "ANONYMOUS"
  type      String   @default("user") // user, system, story, flag, hint
  createdAt DateTime @default(now())
}

model Journal {
  id          String   @id @default(cuid())
  name        String
  description String?
  guidelines  String?  // Submission guidelines
  guidelinesUrl String? // URL to downloadable guidelines file
  coverUrl    String?
  customConfig String? // JSON string for custom homepage design (html/js/css)
  status      String   @default("ACTIVE") // ACTIVE, ARCHIVED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  papers      Novel[]
  submissionTargetNovels Novel[] @relation("SubmissionTargets")
  admins      User[]   @relation("JournalAdmin")
  reviewers   User[]   @relation("JournalReviewers")

  // Universe & Combat System
  combatPower Int      @default(100) // Base combat power + accumulated bonus
  seasonStats UniverseSeasonStat[]
  quizzes     Quiz[]
  
  // Award System
  awardTracks AwardTrack[]
  awardApplications AwardApplication[]
}

model Conference {
  id          String   @id @default(cuid())
  name        String
  description String?
  guidelines  String?  // Submission guidelines
  guidelinesUrl String? // URL to downloadable guidelines file
  coverUrl    String?
  customCssUrl String? // URL to custom CSS file
  location    String?
  startDate   DateTime @default(now())
  endDate     DateTime @default(now())
  status      String   @default("ACTIVE") // ACTIVE, ARCHIVED, COMPLETED, CANCELLED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  papers      Novel[]
  admins      User[]   @relation("ConferenceAdmin")
  reviewers   User[]   @relation("ConferenceReviewers")
}

model Award {
  id          String   @id @default(cuid())
  name        String
  description String?
  criteria    String?  // Selection criteria
  coverUrl    String?
  status      String   @default("ACTIVE") // ACTIVE, ARCHIVED
  
  // Who manages this award (usually SUPER_ADMIN or specific Award Committee)
  admins      User[]   @relation("AwardAdmin")
  
  // 赛道定义
  tracks      AwardTrack[]
  
  // 奖项周期（支持多届）
  cycles      AwardCycle[]
  
  // 奖项等级定义（一等奖、二等奖等，由管理员自定义）
  prizeLevels AwardPrizeLevel[]
  
  // Applications/Nominations for this award
  applications AwardApplication[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 赛道定义
model AwardTrack {
  id          String   @id @default(cuid())
  awardId     String
  award       Award    @relation(fields: [awardId], references: [id], onDelete: Cascade)
  
  name        String   // 赛道名称，如 "理论垃圾"、"实验垃圾"
  description String?  // 赛道描述
  
  // 该赛道关联的期刊（可选，为空则对所有期刊开放）
  journals    Journal[]
  
  order       Int      @default(0) // 排序
  
  // 该赛道的所有申请
  applications AwardApplication[]
  
  createdAt   DateTime @default(now())
  
  @@unique([awardId, name])
}

// 奖项周期（每届奖项）
model AwardCycle {
  id          String   @id @default(cuid())
  awardId     String
  award       Award    @relation(fields: [awardId], references: [id], onDelete: Cascade)
  
  name        String   // 周期名称，如 "2025年度"、"第一届"
  
  // 时间安排
  startDate   DateTime // 申请开始时间
  endDate     DateTime // 申请截止时间
  announceDate DateTime? // 结果公布时间
  
  status      String   @default("UPCOMING") // UPCOMING, OPEN, CLOSED, ANNOUNCED
  
  // 该周期的所有申请
  applications AwardApplication[]
  
  // 该周期的公示
  announcements AwardAnnouncement[]
  
  createdAt   DateTime @default(now())
}

// 奖项等级定义（由管理员自定义）
model AwardPrizeLevel {
  id          String   @id @default(cuid())
  awardId     String
  award       Award    @relation(fields: [awardId], references: [id], onDelete: Cascade)
  
  name        String   // 等级名称，如 "一等奖"、"金奖"
  description String?  // 等级描述
  
  order       Int      @default(0) // 排序（一等奖排前面）
  
  // 视觉样式
  color       String   @default("#FFD700") // 颜色，默认金色
  icon        String?  // 图标
  
  // 获得该等级的申请
  applications AwardApplication[]
  
  createdAt   DateTime @default(now())
  
  @@unique([awardId, name])
}

// 公示公告
model AwardAnnouncement {
  id          String   @id @default(cuid())
  
  cycleId     String
  cycle       AwardCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  
  // 公示内容
  title       String   // 公示标题
  content     String?  // 公示正文（支持Markdown）
  
  // 公示状态
  status      String   @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  
  // 公示时间
  publishAt   DateTime? // 发布时间
  expireAt    DateTime? // 公示截止时间
  
  // 发布人
  publishedBy String?
  publisher   User?    @relation(fields: [publishedBy], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// PPT Contest System
// ==========================================

model PPTSubmission {
  id          String   @id @default(cuid())
  title       String?  // Optional title
  
  // Vercel Blob (Optional if local only)
  fileUrl     String?   
  previewUrl  String?  
  
  // Local Storage (Prioritized)
  localFileUrl    String?
  localPreviewUrl String?

  fileHash    String?  // For deduplication
  
  uploaderIp  String
  uploaderEmail String? // 上传者邮箱
  
  interpretations PPTInterpretation[]
  
  createdAt   DateTime @default(now())
}

model PPTInterpretation {
  id            String   @id @default(cuid())
  
  submissionId  String
  submission    PPTSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  
  audioUrl      String   // Recorded speech URL
  duration      Int?     // Duration in seconds
  
  timestamps    String?  // JSON string: [{"page": 1, "time": 0}, {"page": 2, "time": 15.5}]
  
  speakerIp     String
  
  votes         Int      @default(0)
  
  createdAt     DateTime @default(now())
  
  @@index([votes(sort: Desc)])
}

model AwardApplication {
  id          String   @id @default(cuid())
  
  // 关联奖项
  awardId     String
  award       Award    @relation(fields: [awardId], references: [id])
  
  // 关联周期
  cycleId     String?
  cycle       AwardCycle? @relation(fields: [cycleId], references: [id])

  // 关联赛道
  trackId     String?
  track       AwardTrack? @relation(fields: [trackId], references: [id])
  
  // 申请人信息
  applicantId String?
  applicant   User?    @relation(fields: [applicantId], references: [id])
  
  // 被提名者（可以是个人、团队或期刊）
  nomineeName String?
  nomineeType String   @default("INDIVIDUAL") // INDIVIDUAL, TEAM, JOURNAL
  
  // 关联期刊（新增）
  journalId   String?
  journal     Journal? @relation(fields: [journalId], references: [id])
  
  workDescription String?

  // Linked Papers (Proof of work)
  nominationPapers Novel[] @relation("AwardNominationPapers")
  
  // 评审状态
  status      String   @default("PENDING") // PENDING, REVIEWING, REJECTED, or PRIZE_LEVEL_ID
  
  // 如果获奖，关联到具体等级
  prizeLevelId String?
  prizeLevel   AwardPrizeLevel? @relation(fields: [prizeLevelId], references: [id])
  
  // 评审意见
  reviewComment String?
  reviewedBy  String?
  reviewedAt  DateTime?
  
  // 评审结果是否已发布
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  publishedBy String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Preprint {
  id          String   @id @default(cuid())
  title       String
  abstract    String
  authors     String
  pdfUrl      String
  
  uploaderId  String?
  uploader    User?    @relation(fields: [uploaderId], references: [id])
  uploaderIp  String?

  // Update System
  pendingTitle    String?
  pendingAbstract String?
  pendingAuthors  String?
  pendingPdfUrl   String?
  updateStatus    String   @default("IDLE") // IDLE, PENDING, REJECTED

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UniverseSeason {
  id          String   @id @default(cuid())
  name        String   // e.g. "S1: Genesis"
  startDate   DateTime @default(now())
  endDate     DateTime?
  isActive    Boolean  @default(true)
  
  stats       UniverseSeasonStat[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UniverseSeasonStat {
  id          String   @id @default(cuid())
  
  seasonId    String
  season      UniverseSeason @relation(fields: [seasonId], references: [id])
  
  journalId   String
  journal     Journal  @relation(fields: [journalId], references: [id])
  
  combatPowerContribution Int @default(0) // Contribution in this season
  
  updatedAt   DateTime @updatedAt

  @@unique([seasonId, journalId])
}

model Quiz {
  id          String   @id @default(cuid())
  journalId   String
  journal     Journal  @relation(fields: [journalId], references: [id])
  paperId     String
  paperTitle  String
  
  question    String
  options     String   // JSON string: ["A", "B", "C", "D"]
  correctAnswer Int
  explanation String
  
  difficulty  String   @default("NORMAL")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  attempts    UserQuizAttempt[]
}

model UserQuizAttempt {
  id        String   @id @default(cuid())
  
  quizId    String
  quiz      Quiz     @relation(fields: [quizId], references: [id])
  
  userId    String?  // Optional for guests
  guestIp   String?  // For rate limiting guests
  
  isCorrect Boolean
  
  createdAt DateTime @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  guestName String?  // For anonymous users: "匿名用户xxxx"
  guestIp   String?  // Store IP for rate limiting/blocking if needed
  
  novelId   String
  novel     Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  
  // Optional parent comment for replies
  parentId  String?
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")

  likes     CommentLike[]
}

model CommentLike {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  guestIp   String?  // For anonymous users
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, commentId])
  @@unique([guestIp, commentId])
}

// ==========================================
// Fund System Models (New)
// ==========================================

// 基金大类 (如: NSFC, NSSFC)
model FundCategory {
  id          String   @id @default(cuid())
  name        String   // e.g. "国家自然科学基金"
  code        String   @unique // e.g. "NSFC"
  description String?
  
  // Organization Introduction
  introContent String? // Rich text or markdown
  introImages  String? // JSON string or comma-separated URLs
  
  // 基金管理员：多对多关联，指定谁管理这个大类
  admins      User[]   @relation("FundCategoryAdmins")
  
  funds       Fund[]
  departments FundDepartment[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 基金学部/部门 (如: 数理科学部)
model FundDepartment {
  id          String   @id @default(cuid())
  name        String   // e.g. "数理科学部"
  code        String   // e.g. "1"
  description String?
  
  categoryId  String
  category    FundCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  applications FundApplication[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([categoryId, code])
  @@unique([categoryId, name])
}

// 基金专家档案 (独立于 User 表的扩展信息)
model FundExpertProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  
  realName    String?  // 真实姓名（冗余存储，用于快照）
  title       String?  // 职称 (教授/副教授)
  researchField String? // 研究领域/关键词
  institution String?  // 单位（用于回避原则）
  bankCard    String?  // 银行卡号（发放评审费）
  idCard      String?  // 身份证号
  
  isActive    Boolean  @default(true)
  
  reviews     FundReview[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 具体基金指南/项目 (如: 2026年NSFC面上项目)
model Fund {
  id          String   @id @default(cuid())
  title       String   // e.g. "2026年度面上项目"
  year        Int      // 2026
  
  // New fields for Project No generation
  projectTypeChar String?  // 第4位：项目类别 (字母/数字)
  customNumber    String?  // 第5位：自定义数字
  
  categoryId  String
  category    FundCategory @relation(fields: [categoryId], references: [id])
  
  startDate   DateTime
  endDate     DateTime
  
  status      String   @default("DRAFT") // DRAFT, ACTIVE, CLOSED, ARCHIVED
  guideContent String? // 指南正文(Markdown/HTML)
  
  applications FundApplication[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 申报书 (无需登录，无需关联 User)
model FundApplication {
  id          String   @id @default(cuid())
  serialNo    String?  @unique // 申请编号
  projectNo   String?  @unique // 立项编号
  
  fundId      String
  fund        Fund     @relation(fields: [fundId], references: [id])
  
  applicantName String   // 申请人姓名 (手动填写)
  
  departmentId    String?
  department      FundDepartment? @relation(fields: [departmentId], references: [id])
  departmentName  String?
  departmentCode  String?
  
  title       String   // 项目名称
  description String   // 项目简介
  achievements String? // 项目已有成果（可选）
  
  // 基金项目关联论文成果
  novels      Novel[]
  
  status      String   @default("SUBMITTED") // SUBMITTED, UNDER_REVIEW, APPROVED, REJECTED, WITHDRAWN
  
  reviews     FundReview[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 评审记录
model FundReview {
  id            String   @id @default(cuid())
  
  applicationId String
  application   FundApplication @relation(fields: [applicationId], references: [id])
  
  // 关联到专家档案，而不是直接关联 User，强调专家身份
  expertId      String
  expert        FundExpertProfile @relation(fields: [expertId], references: [id])
  
  score         Float?
  grade         String?  // A, B, C, D
  comments      String?  // 评审意见
  
  status        String   @default("PENDING") // PENDING, SUBMITTED
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model JournalTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   // The JSX/TSX code of the template
  description String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AoiVote {
  id        String   @id @default(cuid())
  novelId   String
  novel     Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  
  ip        String   // Voter IP
  userId    String?  // Optional: Linked User
  
  voteType  String   // OVERREACH (学术过端), MISCONDUCT (学术不端)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([novelId, ip]) // One vote per IP per novel
}

model SearchLog {
  id          String   @id @default(cuid())
  query       String
  userId      String?
  ip          String?
  resultCount Int      @default(0)
  type        String?  // ALL, NOVEL, JOURNAL, etc.
  createdAt   DateTime @default(now())
}

model TrendingTopic {
  id          String   @id @default(cuid())
  keyword     String   @unique
  score       Int      @default(0)
  type        String   @default("AUTO") // AUTO, MANUAL
  url         String?  // Optional redirect URL
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
